{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; connect-src 'self' https://xyeftofxlxbpqctuuqup.supabase.co; img-src 'self' data: blob: https://xyeftofxlxbpqctuuqup.supabase.co; style-src 'self' 'unsafe-inline'; font-src 'self'; object-src 'none'; base-uri 'none'; form-action 'self'; frame-src 'none'; worker-src 'none'; frame-ancestors 'none'"
        },
        {
          "key": "Referrer-Policy",
          "value": "same-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Origin-Agent-Cluster",
          "value": "?1"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/data/(.*)",
      "destination": "/404.html"
    },
    {
      "source": "/images/record-pages/(.*)",
      "destination": "/404.html"
    },
    {
      "source": "/images/quiz/(.*)",
      "destination": "/404.html"
    },
    {
      "source": "/images/private/(.*)",
      "destination": "/404.html"
    }
  ]
}
